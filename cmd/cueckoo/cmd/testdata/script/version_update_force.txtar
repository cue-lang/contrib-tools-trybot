# Test that `cueckoo version update` bypasses the cache.

env _CUECKOO_VERSION_OVERRIDE=v0.99.0
env CUECKOO_DEBUG=1

# First run: populates cache via the pre-command hook.
exec cueckoo rewrite-commit-msg -m msg commit.txt
stderr 'fetching latest info'

# `version update` should always fetch, bypassing the fresh cache.
exec cueckoo version update
stderr 'fetching latest info'
stdout 'cueckoo: already up to date'

-- commit.txt --
original
