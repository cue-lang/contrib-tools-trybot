# When the running binary is not in the `go install` destination directory,
# the pre-command hook must warn instead of silently re-execing the old binary.

env _CUECKOO_VERSION_OVERRIDE=v0.0.1
env GOBIN=$WORK/elsewhere
mkdir $WORK/elsewhere

exec cueckoo rewrite-commit-msg -m msg commit.txt
stderr 'a newer version v0.99.0 is available'
stderr 'not in GOBIN/GOPATH/bin'
! stderr 'cueckoo: updating'

-- commit.txt --
original
