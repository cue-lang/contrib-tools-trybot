# Test that the version cache is used when fresh.

env _CUECKOO_VERSION_OVERRIDE=v0.99.0
env CUECKOO_DEBUG=1

# First run: fetches from proxy and populates cache.
exec cueckoo rewrite-commit-msg -m msg commit.txt
stderr 'fetching latest info'

# Second run: should use the cached version, not fetch again.
exec cueckoo rewrite-commit-msg -m msg commit.txt
stderr 'using cached version'
! stderr 'fetching latest info'

-- commit.txt --
original
