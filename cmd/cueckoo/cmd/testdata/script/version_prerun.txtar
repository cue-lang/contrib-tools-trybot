# Test that the pre-command hook auto-updates and re-execs.

env _CUECKOO_VERSION_OVERRIDE=v0.0.1
exec cueckoo rewrite-commit-msg -m msg commit.txt
stderr 'cueckoo: updating v0.0.1 -> v0.99.0'

# After re-exec, the new (dummy) binary runs with the original args.
stdout 'cueckoo v0.99.0 \[rewrite-commit-msg -m msg commit.txt\]'

-- commit.txt --
original
